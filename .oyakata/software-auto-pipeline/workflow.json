{
  "workflowId": "software-auto-pipeline",
  "description": "Automated software lifecycle: design, discussion, implementation, security, code review, test, and test review.",
  "defaults": {
    "maxLoopIterations": 4,
    "nodeTimeoutMs": 120000
  },
  "prompts": {
    "oyakataPromptTemplate": "Coordinate {{productName}} delivery by planning work, evaluating outputs, and keeping each node instruction tied to the workflow goal.",
    "workerSystemPromptTemplate": "Execute only the assigned node role, use the workflow purpose and provided data, and return the value needed by downstream nodes."
  },
  "managerNodeId": "oyakata-manager",
  "subWorkflows": [
    {
      "id": "main",
      "description": "Software delivery lifecycle",
      "managerNodeId": "main-oyakata",
      "inputNodeId": "workflow-input",
      "outputNodeId": "workflow-output",
      "nodeIds": [
        "main-oyakata",
        "workflow-input",
        "design",
        "design-discuss",
        "implement",
        "security-check",
        "code-review",
        "test",
        "test-review",
        "workflow-output"
      ],
      "inputSources": [
        {
          "type": "human-input"
        }
      ]
    }
  ],
  "nodes": [
    { "id": "oyakata-manager", "kind": "root-manager", "nodeFile": "node-oyakata-manager.json", "completion": { "type": "none" } },
    { "id": "main-oyakata", "kind": "sub-manager", "nodeFile": "node-main-oyakata.json", "completion": { "type": "none" } },
    { "id": "workflow-input", "kind": "input", "nodeFile": "node-workflow-input.json", "completion": { "type": "none" } },
    { "id": "design", "kind": "task", "nodeFile": "node-design.json", "completion": { "type": "none" } },
    { "id": "design-discuss", "kind": "task", "nodeFile": "node-design-discuss.json", "completion": { "type": "none" } },
    { "id": "implement", "kind": "task", "nodeFile": "node-implement.json", "completion": { "type": "none" } },
    { "id": "security-check", "kind": "task", "nodeFile": "node-security-check.json", "completion": { "type": "none" } },
    { "id": "code-review", "kind": "task", "nodeFile": "node-code-review.json", "completion": { "type": "none" } },
    { "id": "test", "kind": "task", "nodeFile": "node-test.json", "completion": { "type": "none" } },
    { "id": "test-review", "kind": "loop-judge", "nodeFile": "node-test-review.json", "completion": { "type": "none" } },
    { "id": "workflow-output", "kind": "output", "nodeFile": "node-workflow-output.json", "completion": { "type": "none" } }
  ],
  "edges": [
    { "from": "workflow-input", "to": "design", "when": "always" },
    { "from": "design", "to": "design-discuss", "when": "always" },
    { "from": "design-discuss", "to": "implement", "when": "always" },
    { "from": "implement", "to": "security-check", "when": "always" },
    { "from": "security-check", "to": "code-review", "when": "always" },
    { "from": "code-review", "to": "test", "when": "always" },
    { "from": "test", "to": "test-review", "when": "always" },
    { "from": "test-review", "to": "implement", "when": "needs_rework" },
    { "from": "test-review", "to": "workflow-output", "when": "approved" }
  ],
  "loops": [
    {
      "id": "implementation-loop",
      "judgeNodeId": "test-review",
      "maxIterations": 2,
      "continueWhen": "needs_rework",
      "exitWhen": "approved",
      "backoffMs": 0
    }
  ],
  "branching": {
    "mode": "fan-out"
  }
}
