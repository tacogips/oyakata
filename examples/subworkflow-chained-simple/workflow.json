{
  "workflowId": "subworkflow-chained-simple",
  "description": "Minimal runnable bundle authored as an ordered node list with two sequential grouped lanes, where beta consumes the published result from alpha.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 120000
  },
  "prompts": {
    "divedraPromptTemplate": "Coordinate {{workflowId}} as two sequential grouped lanes. Run alpha first; after alpha-output succeeds, run beta and pass along the prior published result.",
    "workerSystemPromptTemplate": "Work only on the current node responsibility and return concise business JSON."
  },
  "nodes": [
    {
      "id": "divedra-manager",
      "role": "manager",
      "nodeFile": "node-divedra-manager.json"
    },
    {
      "id": "alpha-manager",
      "group": "alpha-lane",
      "nodeFile": "node-alpha-manager.json"
    },
    {
      "id": "alpha-input",
      "group": "alpha-lane",
      "nodeFile": "node-alpha-input.json"
    },
    {
      "id": "alpha-worker",
      "group": "alpha-lane",
      "nodeFile": "node-alpha-worker.json"
    },
    {
      "id": "alpha-output",
      "group": "alpha-lane",
      "nodeFile": "node-alpha-output.json"
    },
    {
      "id": "beta-manager",
      "group": "beta-lane",
      "nodeFile": "node-beta-manager.json"
    },
    {
      "id": "beta-input",
      "group": "beta-lane",
      "nodeFile": "node-beta-input.json"
    },
    {
      "id": "beta-worker",
      "group": "beta-lane",
      "nodeFile": "node-beta-worker.json"
    },
    {
      "id": "beta-output",
      "group": "beta-lane",
      "nodeFile": "node-beta-output.json"
    }
  ]
}
