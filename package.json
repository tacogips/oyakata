{
  "name": "oyakata",
  "version": "0.1.0",
  "description": "no",
  "type": "module",
  "main": "dist/main.js",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "start": "bun run src/main.ts",
    "test": "vitest run",
    "test:e2e": "playwright test -c playwright.config.cjs",
    "test:all": "bun run test && bun run test:e2e",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "claude-code-agent": "github:tacogips/claude-code-agent#fd9634695b9369902cc1ee01960dd39cbc300b85",
    "codex-agent": "github:tacogips/codex-agent#23cd34cbec18ae10b1868ec154c088b6a2f1c8c1",
    "openai": "6.27.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.1",
    "@types/bun": "1.1.14",
    "@vitest/ui": "2.1.8",
    "typescript": "5.7.2",
    "prettier": "3.4.2",
    "vitest": "2.1.8"
  }
}
